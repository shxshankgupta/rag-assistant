# App
APP_NAME=RAG Knowledge Assistant
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_DIMENSION=1536

# Storage
UPLOAD_DIR=data/uploads
FAISS_INDEX_DIR=data/faiss_index
MAX_UPLOAD_SIZE_MB=50

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# RAG
TOP_K_RESULTS=5
MAX_CONTEXT_TOKENS=4000
CACHE_EMBEDDING_TTL_SECONDS=86400
CACHE_QUERY_RESPONSE_TTL_SECONDS=300
CACHE_CORPUS_VERSION_TTL_SECONDS=2592000
CACHE_MEMORY_MAX_ITEMS=5000
REDIS_URL=redis://localhost:6379/0
# Celery (defaults to REDIS_URL if unset)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
API_RATE_LIMIT_PER_MINUTE=10
QUERY_RATE_LIMIT_PER_MINUTE=5

# Database (SQLite for simplicity; swap to Postgres in prod)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
